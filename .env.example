PORT=3000
# Optional host binding. For an Oracle VM behind Nginx, use HOST=127.0.0.1.
# HOST=0.0.0.0

BUSINESS_NAME=Rahul Prints
BUSINESS_EMAIL=owner@example.com
ORDER_NOTIFICATION_EMAIL=owner@example.com
BUSINESS_PHONE=+919345574203
# Legacy direct UPI fallback. Razorpay is the primary checkout flow now.
UPI_ID=rahulsiva190@okicici

PRICE_BW=1
PRICE_COLOR=10
PAYMENT_TIMEOUT_MINUTES=5
MAX_FORWARDABLE_PDF_MB=18
DRY_RUN_NOTIFICATIONS=false
PDF_ANALYSIS_TIMEOUT_MS=45000
PDF_CONVERSION_TIMEOUT_MS=120000
EMAIL_ATTACHMENT_SAFE_MB=10

# Optional: set this if Node cannot find Python automatically on your machine.
# Example on Windows:
# PYTHON_EXECUTABLE=C:\Users\rahul\AppData\Local\Python\pythoncore-3.14-64\python.exe

# Required for online checkout:
RAZORPAY_KEY_ID=rzp_test_replace_with_your_key_id
RAZORPAY_KEY_SECRET=replace_with_your_razorpay_secret

# Recommended for local testing or your own mailbox: use SMTP.
MAIL_PROVIDER=smtp
# Optional shortcut for a well-known provider such as gmail, outlook365, or zoho.
SMTP_SERVICE=gmail
# Or use direct server settings instead of SMTP_SERVICE:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
SMTP_USER=your_sender@example.com
SMTP_PASS=replace_with_your_smtp_password_or_app_password

# Recommended for free deployment on Render: use the Mailjet Email API over HTTPS.
# Use a verified sender/domain that you own. Avoid free Gmail/Hotmail/Yahoo sender addresses,
# because Mailjet deliverability can fail or land in spam for those domains.
# Keep BUSINESS_EMAIL / ORDER_NOTIFICATION_EMAIL as your real contact inbox if you want,
# but set MAIL_FROM_EMAIL to a verified custom-domain sender such as orders@yourdomain.com.
# MAIL_PROVIDER=mailjet
MAIL_FROM_EMAIL=your_verified_sender@example.com
MAIL_FROM_NAME=Rahul Prints
MJ_APIKEY_PUBLIC=replace_with_your_mailjet_api_key
MJ_APIKEY_PRIVATE=replace_with_your_mailjet_secret_key
# MAILJET_API_BASE=https://api.mailjet.com/v3.1/send

# Render free blocks outbound SMTP ports 25, 465, and 587.
