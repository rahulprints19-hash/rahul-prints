# Recommended for local testing: use Gmail SMTP.
MAIL_PROVIDER=smtp
SMTP_USER=rahulprints19@gmail.com
SMTP_PASS=replace_with_your_gmail_app_password

# Recommended for free deployment on Render: use the Mailjet Email API over HTTPS.
# Use a verified sender/domain that you own. Avoid free Gmail/Hotmail/Yahoo sender addresses,
# because Mailjet deliverability can fail or land in spam for those domains.
# MAIL_PROVIDER=mailjet
MAIL_FROM_EMAIL=rahulprints19@gmail.com
MAIL_FROM_NAME=Rahul Prints
MJ_APIKEY_PUBLIC=replace_with_your_mailjet_api_key
MJ_APIKEY_PRIVATE=replace_with_your_mailjet_secret_key
